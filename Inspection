<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Residential Roofing Master Inspection</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:       #0d1b2a;
    --navy-mid:   #1b2d42;
    --navy-soft:  #243447;
    --steel:      #2c4a6e;
    --blue:       #1e6091;
    --sky:        #2980b9;
    --sky-light:  #ebf5fb;

    --green:      #1a5c38;
    --green-mid:  #27ae60;
    --green-light:#eafaf1;

    --amber:      #b7530a;
    --amber-mid:  #e67e22;
    --amber-light:#fef5e7;

    --red:        #922b21;
    --red-mid:    #e74c3c;
    --red-light:  #fdedec;

    --silver:     #bdc3c7;
    --line:       #d5dde5;
    --bg:         #f0f4f8;
    --white:      #ffffff;
    --text:       #1a2530;
    --text-soft:  #5d7186;

    --check-ok:   #27ae60;
    --check-issue:#e74c3c;
    --check-na:   #7f8c8d;

    --radius:     6px;
    --shadow:     0 2px 12px rgba(0,0,0,.12);
    --shadow-lg:  0 6px 30px rgba(0,0,0,.18);

    --font-head:  'Barlow Condensed', sans-serif;
    --font-body:  'Barlow', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── TOP HEADER ── */
  .site-header {
    background: var(--navy);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 3px 20px rgba(0,0,0,.4);
  }
  .site-header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 56px;
  }
  .header-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .header-icon {
    width: 32px;
    height: 32px;
    background: var(--sky);
    clip-path: polygon(50% 0%, 100% 40%, 80% 100%, 20% 100%, 0% 40%);
    flex-shrink: 0;
  }
  .header-title {
    font-family: var(--font-head);
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: .04em;
    line-height: 1.15;
  }
  .header-title span {
    display: block;
    font-size: .7rem;
    font-weight: 400;
    color: var(--silver);
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .header-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .btn {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: .85rem;
    letter-spacing: .05em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    border-radius: var(--radius);
    padding: 8px 14px;
    transition: all .15s;
    white-space: nowrap;
  }
  .btn-ghost {
    background: rgba(255,255,255,.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,.2);
  }
  .btn-ghost:hover { background: rgba(255,255,255,.2); }
  .btn-primary {
    background: var(--sky);
    color: #fff;
  }
  .btn-primary:hover { background: #1a6fa8; }
  .btn-success {
    background: var(--green-mid);
    color: #fff;
  }
  .btn-success:hover { background: #219150; }

  /* ── PROGRESS BAR ── */
  .progress-bar-wrap {
    background: var(--navy-mid);
    height: 4px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--sky), var(--green-mid));
    transition: width .4s ease;
    width: 0%;
  }

  /* ── MAIN LAYOUT ── */
  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 16px 80px;
  }

  /* ── JOB INFO CARD ── */
  .job-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border-top: 4px solid var(--blue);
    overflow: hidden;
    margin-bottom: 28px;
  }
  .job-card-header {
    background: var(--navy);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .job-card-header h2 {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: .05em;
    text-transform: uppercase;
  }
  .badge {
    background: var(--sky);
    color: #fff;
    font-family: var(--font-head);
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .06em;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
  }
  .job-fields {
    padding: 16px 20px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .field-group label {
    display: block;
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 4px;
  }
  .field-group input,
  .field-group select,
  .field-group textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: .92rem;
    color: var(--text);
    background: var(--bg);
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 8px 10px;
    transition: border-color .15s, box-shadow .15s;
    -webkit-appearance: none;
  }
  .field-group input:focus,
  .field-group select:focus,
  .field-group textarea:focus {
    outline: none;
    border-color: var(--sky);
    box-shadow: 0 0 0 3px rgba(41,128,185,.15);
  }
  .field-group.wide { grid-column: 1 / -1; }

  /* ── SECTION CONTAINER ── */
  .section {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
  }

  .section-header {
    display: flex;
    align-items: stretch;
    cursor: pointer;
    user-select: none;
    min-height: 52px;
  }
  .section-accent {
    width: 6px;
    flex-shrink: 0;
  }
  .section-header-content {
    flex: 1;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-number {
    font-family: var(--font-head);
    font-size: 1.35rem;
    font-weight: 800;
    opacity: .25;
    line-height: 1;
    min-width: 28px;
  }
  .section-info { flex: 1; }
  .section-title {
    font-family: var(--font-head);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .section-subtitle {
    font-size: .75rem;
    color: var(--text-soft);
    margin-top: 2px;
  }
  .section-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .section-count {
    font-family: var(--font-head);
    font-size: .8rem;
    font-weight: 600;
    color: var(--text-soft);
    white-space: nowrap;
  }
  .section-chevron {
    width: 20px;
    height: 20px;
    color: var(--silver);
    transition: transform .25s;
    flex-shrink: 0;
  }
  .section.open .section-chevron { transform: rotate(180deg); }

  .section-body {
    display: none;
    padding: 0 16px 16px;
  }
  .section.open .section-body { display: block; }

  /* ── SUBSECTION ── */
  .subsection { margin-top: 16px; }
  .subsection-title {
    font-family: var(--font-head);
    font-size: .85rem;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: 7px 12px;
    border-radius: var(--radius);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .subsection-title::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 14px;
    border-radius: 2px;
    background: currentColor;
    opacity: .6;
    flex-shrink: 0;
  }

  /* ── CHECK ITEM ── */
  .check-item {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0 10px;
    padding: 10px 8px;
    border-radius: var(--radius);
    border: 1.5px solid transparent;
    margin-bottom: 4px;
    transition: background .1s, border-color .1s;
  }
  .check-item:hover { background: var(--bg); }
  .check-item.status-ok    { background: var(--green-light); border-color: #a9dfbf; }
  .check-item.status-issue { background: var(--red-light);   border-color: #f5b7b1; }
  .check-item.status-na    { background: #f8f9fa;            border-color: var(--line); opacity: .65; }

  .check-controls {
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-top: 1px;
  }
  .status-btn {
    width: 36px;
    height: 24px;
    border-radius: 4px;
    border: 1.5px solid;
    font-family: var(--font-head);
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .04em;
    cursor: pointer;
    transition: all .12s;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .status-btn.ok    { border-color: #a9dfbf; color: var(--check-ok);    background: transparent; }
  .status-btn.issue { border-color: #f5b7b1; color: var(--check-issue); background: transparent; }
  .status-btn.na    { border-color: var(--line); color: var(--check-na); background: transparent; }

  .status-btn.ok.active    { background: var(--check-ok);    color: #fff; border-color: var(--check-ok); }
  .status-btn.issue.active { background: var(--check-issue); color: #fff; border-color: var(--check-issue); }
  .status-btn.na.active    { background: var(--check-na);    color: #fff; border-color: var(--check-na); }

  .check-label {
    font-size: .92rem;
    line-height: 1.4;
    padding-top: 2px;
    grid-column: 2;
  }
  .check-notes {
    grid-column: 2;
    margin-top: 6px;
    display: none;
  }
  .check-item.status-issue .check-notes,
  .check-item.always-notes .check-notes { display: block; }

  .check-notes input {
    width: 100%;
    font-family: var(--font-body);
    font-size: .83rem;
    color: var(--text);
    background: rgba(255,255,255,.8);
    border: 1px solid #f1948a;
    border-radius: 4px;
    padding: 5px 8px;
  }
  .check-item.status-ok .check-notes input {
    border-color: var(--line);
  }
  .check-notes input:focus { outline: none; border-color: var(--sky); box-shadow: 0 0 0 2px rgba(41,128,185,.12); }
  .check-notes input::placeholder { color: #bbb; font-style: italic; }

  /* ── FREE NOTES BLOCK ── */
  .notes-block {
    margin-top: 14px;
  }
  .notes-block label {
    display: block;
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: .07em;
    margin-bottom: 5px;
  }
  .notes-block textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: .88rem;
    color: var(--text);
    background: var(--bg);
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 9px 11px;
    resize: vertical;
    min-height: 72px;
  }
  .notes-block textarea:focus {
    outline: none;
    border-color: var(--sky);
    box-shadow: 0 0 0 3px rgba(41,128,185,.12);
  }

  /* ── SECTION COLORS ── */
  /* pre-inspection */
  [data-phase="pre"] .section-accent { background: var(--green); }
  [data-phase="pre"] .section-number { color: var(--green); opacity: .4; }
  [data-phase="pre"] .section-title  { color: var(--green); }
  [data-phase="pre"] .subsection-title { background: var(--green-light); color: var(--green); }

  /* surface */
  [data-phase="surface"] .section-accent { background: var(--blue); }
  [data-phase="surface"] .section-number { color: var(--blue); opacity: .4; }
  [data-phase="surface"] .section-title  { color: var(--blue); }
  [data-phase="surface"] .subsection-title { background: var(--sky-light); color: var(--blue); }

  /* flashings */
  [data-phase="flash"] .section-accent { background: var(--amber); }
  [data-phase="flash"] .section-number { color: var(--amber); opacity: .4; }
  [data-phase="flash"] .section-title  { color: var(--amber); }
  [data-phase="flash"] .subsection-title { background: var(--amber-light); color: var(--amber); }

  /* gutters */
  [data-phase="gutter"] .section-accent { background: #7d3c98; }
  [data-phase="gutter"] .section-number { color: #7d3c98; opacity: .4; }
  [data-phase="gutter"] .section-title  { color: #7d3c98; }
  [data-phase="gutter"] .subsection-title { background: #f5eef8; color: #7d3c98; }

  /* attic */
  [data-phase="attic"] .section-accent { background: #17a589; }
  [data-phase="attic"] .section-number { color: #17a589; opacity: .4; }
  [data-phase="attic"] .section-title  { color: #17a589; }
  [data-phase="attic"] .subsection-title { background: #e8f8f5; color: #17a589; }

  /* summary */
  [data-phase="summary"] .section-accent { background: var(--red-mid); }
  [data-phase="summary"] .section-number { color: var(--red-mid); opacity: .4; }
  [data-phase="summary"] .section-title  { color: var(--red-mid); }
  [data-phase="summary"] .subsection-title { background: var(--red-light); color: var(--red); }

  /* ── SUMMARY / RATING ── */
  .rating-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 8px;
    margin-bottom: 16px;
  }
  .rating-btn {
    padding: 10px 8px;
    border-radius: var(--radius);
    border: 2px solid var(--line);
    background: var(--bg);
    font-family: var(--font-head);
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: .04em;
    cursor: pointer;
    text-align: center;
    transition: all .15s;
    color: var(--text-soft);
  }
  .rating-btn:hover { border-color: var(--sky); color: var(--sky); }
  .rating-btn.selected { color: #fff; }
  .rating-btn[data-rating="excellent"].selected  { background: #1a8a4c; border-color: #1a8a4c; }
  .rating-btn[data-rating="verygood"].selected   { background: #27ae60; border-color: #27ae60; }
  .rating-btn[data-rating="good"].selected       { background: #2e86c1; border-color: #2e86c1; }
  .rating-btn[data-rating="fair"].selected       { background: #d68910; border-color: #d68910; }
  .rating-btn[data-rating="poor"].selected       { background: #ca6f1e; border-color: #ca6f1e; }
  .rating-btn[data-rating="failed"].selected     { background: #c0392b; border-color: #c0392b; }

  .action-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
  }
  .action-btn {
    padding: 12px 8px;
    border-radius: var(--radius);
    border: 2px solid var(--line);
    background: var(--bg);
    font-family: var(--font-head);
    font-size: .85rem;
    font-weight: 700;
    letter-spacing: .04em;
    cursor: pointer;
    text-align: center;
    transition: all .15s;
    color: var(--text-soft);
    line-height: 1.3;
  }
  .action-btn[data-action="repair"].selected   { background: var(--green-mid); border-color: var(--green-mid); color: #fff; }
  .action-btn[data-action="replace"].selected  { background: var(--red-mid); border-color: var(--red-mid); color: #fff; }
  .action-btn[data-action="monitor"].selected  { background: var(--amber-mid); border-color: var(--amber-mid); color: #fff; }

  /* ── SIGNATURE ── */
  .sig-wrap {
    margin-top: 12px;
  }
  .sig-wrap label {
    display: block;
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: .07em;
    margin-bottom: 6px;
  }
  canvas.sig-pad {
    width: 100%;
    height: 100px;
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg);
    cursor: crosshair;
    touch-action: none;
    display: block;
  }
  .sig-actions {
    display: flex;
    gap: 8px;
    margin-top: 6px;
  }
  .btn-sm {
    font-family: var(--font-head);
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }

  /* ── TOAST ── */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--navy);
    color: #fff;
    font-family: var(--font-head);
    font-size: .9rem;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 30px;
    box-shadow: var(--shadow-lg);
    z-index: 999;
    transition: transform .3s cubic-bezier(.175,.885,.32,1.275);
    pointer-events: none;
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ── PRINT ── */
  @media print {
    .site-header, .header-actions, .toast { display: none; }
    .section { page-break-inside: avoid; }
    .section-body { display: block !important; }
    body { background: #fff; }
    .check-notes { display: block !important; }
    canvas.sig-pad { border: 1px solid #ccc; }
  }

  @media (max-width: 480px) {
    .action-grid { grid-template-columns: 1fr; }
    .header-title { font-size: 1rem; }
    .btn { padding: 7px 10px; font-size: .78rem; }
  }
</style>
</head>
<body>

<!-- ── STICKY HEADER ── -->
<header class="site-header">
  <div class="site-header-inner">
    <div class="header-brand">
      <div class="header-icon"></div>
      <div class="header-title">
        Roofing Inspection
        <span>Residential Master Checklist</span>
      </div>
    </div>
    <div class="header-actions">
      <button class="btn btn-ghost" onclick="saveDraft()">Save</button>
      <button class="btn btn-ghost" onclick="window.print()">Print</button>
      <button class="btn btn-primary" onclick="exportSummary()">Export</button>
    </div>
  </div>
  <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progressBar"></div></div>
</header>

<div class="main" id="app">

  <!-- ── JOB INFO ── -->
  <div class="job-card">
    <div class="job-card-header">
      <h2>Job Information</h2>
      <span class="badge">Field Form</span>
    </div>
    <div class="job-fields">
      <div class="field-group"><label>Inspector Name</label><input type="text" id="fi_inspector" placeholder="Full name"></div>
      <div class="field-group"><label>Inspection Date</label><input type="date" id="fi_date"></div>
      <div class="field-group"><label>Weather Conditions</label><input type="text" id="fi_weather" placeholder="Clear, cloudy, temp…"></div>
      <div class="field-group wide"><label>Property Address</label><input type="text" id="fi_address" placeholder="Street, City, State, ZIP"></div>
      <div class="field-group"><label>Homeowner Name</label><input type="text" id="fi_owner" placeholder=""></div>
      <div class="field-group"><label>Roof Age (approx.)</label><input type="text" id="fi_age" placeholder="e.g. 18 years"></div>
      <div class="field-group"><label>Roof Material</label>
        <select id="fi_material">
          <option value="">Select…</option>
          <option>3-Tab Asphalt Shingles</option>
          <option>Architectural / Dimensional Shingles</option>
          <option>Impact-Rated Asphalt Shingles</option>
          <option>Standing Seam Metal</option>
          <option>Exposed Fastener Metal</option>
          <option>Concrete Tile</option>
          <option>Clay Tile</option>
          <option>Natural Slate</option>
          <option>Wood Shake / Shingle</option>
          <option>TPO Flat Membrane</option>
          <option>EPDM Flat Membrane</option>
          <option>Built-Up Roofing (BUR)</option>
          <option>Modified Bitumen</option>
        </select>
      </div>
      <div class="field-group"><label>Roof Size (approx. SQ)</label><input type="text" id="fi_size" placeholder="e.g. 28 squares"></div>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════
       SECTION 1 — PRE-INSPECTION
  ═════════════════════════════════════════════════════════ -->
  <div class="section open" data-phase="pre" data-section="1">
    <div class="section-header" onclick="toggleSection(this)">
      <div class="section-accent"></div>
      <div class="section-header-content">
        <div class="section-number">01</div>
        <div class="section-info">
          <div class="section-title">Pre-Inspection</div>
          <div class="section-subtitle">Complete before accessing the roof</div>
        </div>
        <div class="section-meta">
          <span class="section-count" id="count_1">0 / 0</span>
          <svg class="section-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
    </div>
    <div class="section-body">

      <div class="subsection">
        <div class="subsection-title">Safety & Conditions</div>
        <div id="items_1_safety"></div>
      </div>

      <div class="subsection">
        <div class="subsection-title">Documentation & Tools</div>
