function renderItems() {
  Object.entries(CHECKLIST).forEach(([key, items]) => {
    const container = document.getElementById('items_' + key);
    if (!container) return;
    items.forEach((text, idx) => {
      const id = `item_${key}_${idx}`;
      const div = document.createElement('div');
      div.className = 'check-item';
      div.id = id;
      div.innerHTML = `
        <div class="check-controls">
          <button class="status-btn ok"    onclick="setStatus('${id}','ok')"    title="OK">OK</button>
          <button class="status-btn issue" onclick="setStatus('${id}','issue')" title="Issue">!</button>
          <button class="status-btn na"    onclick="setStatus('${id}','na')"    title="N/A">N/A</button>
        </div>
        <div class="check-label">${text}</div>
        <div class="check-notes">
          <input type="text" placeholder="Note issue details, location, photos taken…" 
                 id="note_${id}" onchange="saveDraftSilent()">
        </div>`;
      container.appendChild(div);
    });
  });
  updateAllCounts();
}

// ═══════════════════════════════════════════════════════════════
// SECTION TOGGLE
// ═══════════════════════════════════════════════════════════════
function toggleSection(header) {
  const section = header.closest('.section');
  section.classList.toggle('open');
}

// ═══════════════════════════════════════════════════════════════
// STATUS HANDLING
// ═══════════════════════════════════════════════════════════════
function setStatus(itemId, status) {
  const item = document.getElementById(itemId);
  item.classList.remove('status-ok', 'status-issue', 'status-na');
  item.querySelectorAll('.status-btn').forEach(b => b.classList.remove('active'));

  if (status) {
    item.classList.add('status-' + status);
    item.querySelector('.status-btn.' + status).classList.add('active');
    item.dataset.status = status;
  } else {
    delete item.dataset.status;
  }
  updateSectionCount(item.closest('.section').dataset.section);
  updateProgress();
  saveDraftSilent();
}

function updateSectionCount(sectionNum) {
  const section = document.querySelector(`[data-section="${sectionNum}"]`);
  if (!section) return;
  const items = section.querySelectorAll('.check-item');
  const done  = section.querySelectorAll('.check-item[data-status]').length;
  const count = document.getElementById(`count_${sectionNum}`);
  if (count) count.textContent = `${done} / ${items.length}`;
}

function updateAllCounts() {
  for (let i = 1; i <= 5; i++) updateSectionCount(i);
  updateProgress();
}

function updateProgress() {
  const all  = document.querySelectorAll('.check-item').length;
  const done = document.querySelectorAll('.check-item[data-status]').length;
  const pct  = all > 0 ? Math.round((done / all) * 100) : 0;
  document.getElementById('progressBar').style.width = pct + '%';
}

